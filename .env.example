# Meta WhatsApp Cloud API (developers.facebook.com > your App > WhatsApp > API Setup)
VERIFY_TOKEN=choose_any_random_string_here
WHATSAPP_TOKEN=paste_your_temporary_or_permanent_access_token
PHONE_NUMBER_ID=paste_phone_number_id_from_meta_dashboard

# Comma-separated list of advisors for round-robin lead assignment
ADVISOR_NAMES=Rohit,Priya,Aman

# OPTIONAL - free internal notifications via a Telegram bot instead of email/SMS.
# 1. Message @BotFather on Telegram -> /newbot -> copy the token below
# 2. Message your new bot once, then visit:
#    https://api.telegram.org/bot<token>/getUpdates  to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

PORT=3000
